# .env.example
# Copy this to .env.local and fill in your values.
# NEVER commit .env.local to git.

# ── Supabase ───────────────────────────────────────────────────────────────
# From: https://supabase.com/dashboard → Project Settings → API

NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Service role key — only used server-side, never expose to client
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# ── Database ───────────────────────────────────────────────────────────────
# From: Supabase → Project Settings → Database → Connection string
# Use the "Transaction" mode URL for the pooled connection (Prisma runtime)
# Use the "Session" mode URL for migrations (direct URL)

DATABASE_URL=postgresql://postgres.[PROJECT_ID]:[PASSWORD]@aws-0-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres.[PROJECT_ID]:[PASSWORD]@aws-0-us-east-1.pooler.supabase.com:5432/postgres

# ── App ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Notifications (optional — configure after launch) ─────────────────────
# SendGrid — for email confirmations
SENDGRID_API_KEY=SG.your_key_here
SENDGRID_FROM_EMAIL=reservations@hivebuckhead.com

# Twilio — for SMS confirmations
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE_NUMBER=+14045550000

# SendGrid (email notifications — confirm + cancel)
SENDGRID_API_KEY=your_sendgrid_api_key_here
SENDGRID_FROM_EMAIL=reservations@hivebuckhead.com
