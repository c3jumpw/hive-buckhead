// =============================================================================
// prisma/schema.prisma
// Hive Buckhead — Complete Data Model v3.0
//
// Purpose: Single source of truth for all database tables.
// Responsibilities:
//   - Staff authentication, roles, profiles, onboarding, offboarding
//   - Reservations, tables, floor management
//   - Scheduling (recurring + override), callouts
//   - Messaging logs (SendGrid/Twilio)
//   - System settings, operating hours
//   - Staff feedback, announcements, message blasts
//   - Onboarding portal with rotating access code
//
// Run: npx prisma generate && npx prisma db push
// =============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// =============================================================================
// ENUMS
// =============================================================================

// Access hierarchy: OWNER > MANAGER > STAFF
// OWNER   — full system access including destructive actions + staff portal
// MANAGER — all operational features + staff portal, no system-level destructive ops
// STAFF   — staff portal only (schedule, floor read-only, announcements, feedback)
enum AccessLevel {
  OWNER
  MANAGER
  STAFF
}

// Staff employment status — tracks lifecycle from active to terminated
enum EmploymentStatus {
  ACTIVE
  INACTIVE
  TERMINATED
  ON_LEAVE
}

enum ReservationStatus {
  REQUESTED
  CONFIRMED
  SEATED
  COMPLETED
  CANCELLED
  CHANGE_REQUESTED
  CANCELLATION_REQUESTED
}

enum Section {
  FINE_DINING
  BAR
  DEN
  PATIO
}

enum TableState {
  AVAILABLE
  RESERVED
  SEATED
  DIRTY
  MAINTENANCE
}

// Shift types used in scheduling
enum ShiftType {
  OPEN    // morning open shift
  MID     // midday shift
  CLOSE   // evening close shift
  DOUBLE  // full day
}

enum CalloutReason {
  SICK
  PERSONAL
  FAMILY_EMERGENCY
  NO_CALL_NO_SHOW
  APPROVED_PTO
  OTHER
}

enum MessageChannel {
  EMAIL
  SMS
}

// Onboarding document signing status
enum SigningStatus {
  PENDING
  SIGNED
  DECLINED
}

// =============================================================================
// STAFF POSITIONS (admin-managed list of roles/positions)
// =============================================================================

// Represents a job position that can be assigned to staff members.
// Admins can create new positions without touching code.
model Position {
  id          String   @id @default(cuid())
  name        String   @unique  // e.g. "Server", "Bartender", "Busser", "Kitchen"
  description String?
  department  String?  // e.g. "FOH", "BOH", "Management"
  active      Boolean  @default(true)

  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  staff       Staff[]

  @@map("positions")
}

// =============================================================================
// STAFF / AUTH
// =============================================================================

// Core staff record. Covers both admin-level and portal-level users.
// PIN is hashed with bcrypt. TeamId format: AA-001 (auto-generated on onboarding).
// Approval gate for staff created through the public onboarding portal.
// BUG HISTORY (2026-07-15): before this field existed, onboarding/submit
// created Staff records with the schema default `active: true`, meaning a
// new hire was immediately visible everywhere (staff lists, login dropdown,
// dashboard counts) the moment they finished the form — with no admin
// review step at all. This enum + the approvalStatus field on Staff close
// that gap: onboarding submissions now default to PENDING + active:false,
// and every existing query that already filters `active: true` (staff-list,
// admin staff tab, dashboard) automatically excludes them with zero further
// changes, until an admin explicitly approves.
enum OnboardingApprovalStatus {
  INVITED   // 2026-07-16 addition — admin invited this person but they
            // haven't completed the onboarding form yet. active:false,
            // onboardingCompleted:false. Distinct from PENDING (which
            // means the form WAS completed and is awaiting review) so
            // "invited, waiting on them" and "submitted, waiting on us"
            // don't collapse into the same state in the UI.
  PENDING   // awaiting admin review — set by onboarding/submit
  APPROVED  // admin approved — staff.active flips to true
  REJECTED  // admin rejected — stays inactive permanently, record kept for audit
}

model Staff {
  id              String           @id @default(cuid())
  teamId          String?          @unique @map("team_id")       // "AA-001" format
  name            String
  email           String           @unique
  phone           String?
  positionId      String?          @map("position_id")
  position        Position?        @relation(fields: [positionId], references: [id])
  role            String           // legacy field, keep for display
  accessLevel     AccessLevel      @default(STAFF) @map("access_level")
  employmentStatus EmploymentStatus @default(ACTIVE) @map("employment_status")
  pin             String           // bcrypt-hashed PIN code
  color           String           @default("#C9A96E")
  section         Section?
  // Master visibility switch. false = invisible to login, staff lists,
  // dashboards, everywhere. Staff added directly by an admin default to
  // true (the admin IS the approval). Onboarding-portal submissions
  // explicitly override this to false at creation — see submit route.
  active          Boolean          @default(true)
  avatarUrl       String?          @map("avatar_url")
  notes           String?          // admin-only internal notes

  // Onboarding tracking
  onboardingCompleted Boolean   @default(false) @map("onboarding_completed")
  onboardingCompletedAt DateTime? @map("onboarding_completed_at")

  // Approval gate — only meaningful when onboardingCompleted is true.
  // Staff created directly by an admin (not through the portal) default to
  // APPROVED since no review step applies to them.
  approvalStatus  OnboardingApprovalStatus @default(APPROVED) @map("approval_status")
  approvedAt      DateTime?        @map("approved_at")
  approvedBy      String?          @map("approved_by")  // admin name who approved/rejected

  // Offboarding tracking
  terminatedAt    DateTime?        @map("terminated_at")
  terminationNotes String?         @map("termination_notes")
  terminatedBy    String?          @map("terminated_by")  // staff name who processed

  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")

  // Relations
  reservations      Reservation[]       @relation("ServerReservations")
  confirmedBy       Reservation[]       @relation("ConfirmedBy")
  closedBy          Reservation[]       @relation("ClosedBy")
  shifts            Shift[]
  recurringShifts   RecurringShift[]
  callouts          Callout[]
  coveredCallouts   Callout[]           @relation("CoveredBy")
  activityLogs      ActivityLog[]
  messageLogs       MessageLog[]
  onboardingRecord  OnboardingRecord?
  feedback          StaffFeedback[]
  receivedAnnouncements AnnouncementRead[]

  @@map("staff")
}

// =============================================================================
// ONBOARDING
// =============================================================================

// Controls access to the onboarding portal.
// Password rotates weekly (cron) or manually via admin button.
// Format: random 8-char alphanumeric, stored hashed in DB, plain shown to admin.
model OnboardingPortalConfig {
  id              String   @id @default("singleton")
  // Hashed password — compare with bcrypt on portal entry
  accessCodeHash  String   @map("access_code_hash")
  // Plain text shown ONLY to admins in the dashboard (never to portal users)
  accessCodePlain String   @map("access_code_plain")
  // When the code was last rotated — used to trigger weekly auto-rotation
  rotatedAt       DateTime @default(now()) @map("rotated_at")
  // Next scheduled rotation date
  nextRotationAt  DateTime @map("next_rotation_at")

  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("onboarding_portal_config")
}

// One onboarding record per staff member.
// Tracks document signing, uploaded files, and completion status.
model OnboardingRecord {
  id              String        @id @default(cuid())
  staffId         String        @unique @map("staff_id")
  staff           Staff         @relation(fields: [staffId], references: [id])

  // Personal info captured during onboarding
  legalName       String?       @map("legal_name")
  dateOfBirth     String?       @map("date_of_birth")   // stored as string for privacy
  address         String?
  emergencyContact String?      @map("emergency_contact")
  emergencyPhone  String?       @map("emergency_phone")
  tshirtSize      String?       @map("tshirt_size")
  startDate       DateTime?     @map("start_date") @db.Date

  // Document uploads — REVISION (2026-07-15): comment corrected. These
  // store a PRIVATE Supabase Storage PATH, not a public URL — the
  // document lives in a non-public bucket (hive-onboarding-docs) and can
  // only be viewed via a short-lived signed URL generated on demand for
  // an authenticated admin (see /api/onboarding/document-url). Never
  // render idDocumentUrl directly as an <img src> — it is a storage path,
  // not a fetchable URL on its own.
  idDocumentUrl   String?       @map("id_document_url")
  additionalDocsUrls String[]   @map("additional_docs_urls")

  // Digital signature (2026-07-15 addition) — a typed full legal name
  // functions as a valid electronic signature under the US ESIGN Act and
  // UETA (this is the same mechanism used by most consumer e-signature
  // flows for standard agreements — full canvas/drawn signatures exist
  // but aren't legally required for validity). Combined with the existing
  // checkbox acknowledgment and ipAddressOnSign below for the audit trail.
  signatureText   String?       @map("signature_text")
  signedAt        DateTime?     @map("signed_at")

  // Legal document signing — each doc tracked separately
  employmentAgreementStatus SigningStatus @default(PENDING) @map("employment_agreement_status")
  employmentAgreementSignedAt DateTime?   @map("employment_agreement_signed_at")
  
  codeOfConductStatus SigningStatus @default(PENDING) @map("code_of_conduct_status")
  codeOfConductSignedAt DateTime?   @map("code_of_conduct_signed_at")

  ipAddressOnSign String?       @map("ip_address_on_sign") // audit trail for signatures

  completedAt     DateTime?     @map("completed_at")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  @@map("onboarding_records")
}

// =============================================================================
// OFFBOARDING
// =============================================================================

// Records the offboarding process when a staff member is terminated.
// Preserves history without deleting staff record.
model OffboardingRecord {
  id              String   @id @default(cuid())
  staffId         String   @map("staff_id")   // staff.id — not a relation, preserve after deactivation
  staffName       String   @map("staff_name") // denormalized for historical record
  staffEmail      String   @map("staff_email")
  staffTeamId     String?  @map("staff_team_id")

  // Offboarding details
  terminationDate DateTime @map("termination_date") @db.Date
  terminationType String   @map("termination_type")  // "voluntary" | "involuntary" | "layoff" | "contract_end"
  reason          String?
  notes           String?  // admin internal notes
  processedBy     String   @map("processed_by")  // admin name

  // Checklist — what was completed during offboarding
  accessRevoked   Boolean  @default(false) @map("access_revoked")
  equipmentReturned Boolean @default(false) @map("equipment_returned")
  finalPayProcessed Boolean @default(false) @map("final_pay_processed")
  exitInterviewDone Boolean @default(false) @map("exit_interview_done")

  createdAt       DateTime @default(now()) @map("created_at")

  @@map("offboarding_records")
}

// =============================================================================
// TABLES (floor configuration)
// =============================================================================

model Table {
  id          String     @id @default(cuid())
  displayId   String     @unique @map("display_id")
  label       String?
  capacity    Int
  section     Section
  state       TableState @default(AVAILABLE)
  svgX        Float      @map("svg_x")
  svgY        Float      @map("svg_y")
  svgW        Float?     @map("svg_w")
  svgH        Float?     @map("svg_h")
  svgShape    String?    @map("svg_shape")
  active      Boolean    @default(true)
  notes       String?

  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  reservationTables ReservationTable[]
  stateHistory      TableStateLog[]

  @@map("tables")
}

model TableStateLog {
  id        String     @id @default(cuid())
  tableId   String     @map("table_id")
  table     Table      @relation(fields: [tableId], references: [id])
  fromState TableState @map("from_state")
  toState   TableState @map("to_state")
  changedBy String?    @map("changed_by")
  note      String?
  createdAt DateTime   @default(now()) @map("created_at")

  @@map("table_state_logs")
}

// =============================================================================
// RESERVATIONS
// =============================================================================

model Reservation {
  id            String            @id @default(cuid())
  rsvpCode      String            @unique @map("rsvp_code")
  firstName     String            @map("first_name")
  lastName      String            @map("last_name")
  phone         String
  email         String?
  date          DateTime          @db.Date
  arrivalTime   String            @map("arrival_time")
  partySize     Int               @map("party_size")
  section       Section?
  occasion      String?
  notes         String?
  source        String            @default("web_form")
  status        ReservationStatus @default(REQUESTED)
  orderTotal    Decimal?          @db.Decimal(10, 2) @map("order_total")
  tipAmount     Decimal?          @db.Decimal(10, 2) @map("tip_amount")
  closingRemarks String?          @map("closing_remarks")
  receiptUrl    String?           @map("receipt_url")
  changeRequest Json?             @map("change_request")

  serverId      String?           @map("server_id")
  server        Staff?            @relation("ServerReservations", fields: [serverId], references: [id])
  confirmedById String?           @map("confirmed_by_id")
  confirmedBy   Staff?            @relation("ConfirmedBy", fields: [confirmedById], references: [id])
  closedById    String?           @map("closed_by_id")
  closedBy      Staff?            @relation("ClosedBy", fields: [closedById], references: [id])

  confirmedAt   DateTime?         @map("confirmed_at")
  seatedAt      DateTime?         @map("seated_at")
  completedAt   DateTime?         @map("completed_at")
  cancelledAt   DateTime?         @map("cancelled_at")
  createdAt     DateTime          @default(now()) @map("created_at")
  updatedAt     DateTime          @updatedAt @map("updated_at")

  tables        ReservationTable[]
  messages      MessageLog[]
  activity      ActivityLog[]

  @@index([date])
  @@index([status])
  @@index([phone])
  @@index([rsvpCode])
  @@map("reservations")
}

model ReservationTable {
  reservationId String      @map("reservation_id")
  tableId       String      @map("table_id")
  reservation   Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  table         Table       @relation(fields: [tableId], references: [id])
  assignedAt    DateTime    @default(now()) @map("assigned_at")

  @@id([reservationId, tableId])
  @@map("reservation_tables")
}

// =============================================================================
// ACTIVITY & MESSAGING LOGS
// =============================================================================

model ActivityLog {
  id            String       @id @default(cuid())
  reservationId String?      @map("reservation_id")
  reservation   Reservation? @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  staffId       String?      @map("staff_id")
  staff         Staff?       @relation(fields: [staffId], references: [id])
  type          String
  description   String
  metadata      Json?

  createdAt     DateTime     @default(now()) @map("created_at")

  @@index([reservationId])
  @@map("activity_logs")
}

// =============================================================================
// MESSAGE TEMPLATES
// =============================================================================

// Reusable message templates for the quick-send buttons on a reservation's
// detail panel (Confirm / Reminder / Thank You, etc.), editable by admins.
//
// BUG HISTORY (2026-07-15): before this model existed, the "Messages" admin
// tab had a fully-built editor UI whose Save button only updated in-memory
// React state — every edit vanished on page refresh, because there was
// nothing to persist to. Separately, the actual quick-send buttons on each
// reservation's detail panel used a completely different, hardcoded set of
// three templates baked directly into that component. The two systems never
// talked to each other: editing a template in the admin tab had zero effect
// on what staff actually sent to guests. This model unifies both into one
// real, persisted source of truth.
//
// `body` supports {{placeholder}} tokens — firstName, lastName, date, time,
// partySize, rsvpCode — substituted at send time by renderTemplate() in
// src/lib/utils/index.ts. Admins can edit wording freely without touching
// code, as long as they keep the {{...}} tokens they want populated.
model MessageTemplate {
  id        String         @id @default(cuid())
  name      String         // e.g. "Confirm", "Reminder", "Thank You"
  channel   MessageChannel // EMAIL or SMS — body content and length expectations differ
  subject   String?        // email only; ignored for SMS
  body      String         // supports {{firstName}} {{date}} {{time}} {{partySize}} {{rsvpCode}}
  active    Boolean        @default(true)

  createdAt DateTime       @default(now()) @map("created_at")
  updatedAt DateTime       @updatedAt @map("updated_at")

  @@map("message_templates")
}

model MessageLog {
  id            String         @id @default(cuid())
  reservationId String?        @map("reservation_id")
  reservation   Reservation?   @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  staffId       String?        @map("staff_id")
  staff         Staff?         @relation(fields: [staffId], references: [id])
  channel       MessageChannel
  recipient     String
  subject       String?
  body          String
  sentAt        DateTime       @default(now()) @map("sent_at")
  status        String         @default("sent")
  externalId    String?        @map("external_id")

  @@map("message_logs")
}

// =============================================================================
// SCHEDULING
// =============================================================================

// Individual shift (specific date)
model Shift {
  id          String    @id @default(cuid())
  staffId     String    @map("staff_id")
  staff       Staff     @relation(fields: [staffId], references: [id])
  date        DateTime  @db.Date
  startTime   String    @map("start_time")
  endTime     String    @map("end_time")
  type        ShiftType @default(CLOSE)
  role        String?
  notes       String?
  // Flag: was this shift generated from a recurring schedule?
  isRecurring Boolean   @default(false) @map("is_recurring")
  createdBy   String?   @map("created_by")

  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@index([date])
  @@index([staffId])
  @@map("shifts")
}

// Recurring shift template — defines a staff member's default weekly schedule.
// Day 0=Sunday, 1=Monday, ... 6=Saturday.
// Admin can set defaults per staff member; individual weeks can override via Shift.
model RecurringShift {
  id          String    @id @default(cuid())
  staffId     String    @map("staff_id")
  staff       Staff     @relation(fields: [staffId], references: [id])
  // Day of week this recurring shift applies to
  dayOfWeek   Int       @map("day_of_week")  // 0-6
  startTime   String    @map("start_time")
  endTime     String    @map("end_time")
  type        ShiftType @default(CLOSE)
  role        String?
  // If false, this day is a regular day off for this staff member
  isWorkDay   Boolean   @default(true) @map("is_work_day")
  active      Boolean   @default(true)

  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@unique([staffId, dayOfWeek])  // one recurring shift per day per staff member
  @@map("recurring_shifts")
}

model Callout {
  id            String        @id @default(cuid())
  staffId       String        @map("staff_id")
  staff         Staff         @relation(fields: [staffId], references: [id])
  date          DateTime      @db.Date
  reason        CalloutReason
  coveredById   String?       @map("covered_by_id")
  coveredBy     Staff?        @relation("CoveredBy", fields: [coveredById], references: [id])
  notes         String?
  loggedBy      String?       @map("logged_by")

  createdAt     DateTime      @default(now()) @map("created_at")

  @@index([date])
  @@index([staffId])
  @@map("callouts")
}

// =============================================================================
// STAFF COMMUNICATION
// =============================================================================

// Announcements sent from admin/manager to all or specific staff.
// Supports message blasts to the whole team.
model Announcement {
  id          String   @id @default(cuid())
  title       String
  body        String
  // Target: "all" | "servers" | "bartenders" | specific accessLevel
  targetGroup String   @default("all") @map("target_group")
  pinned      Boolean  @default(false)  // pinned announcements stay at top
  authorId    String?  @map("author_id")  // staff.id of sender
  authorName  String   @map("author_name")

  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  reads       AnnouncementRead[]

  @@map("announcements")
}

// Tracks which staff have read each announcement
model AnnouncementRead {
  announcementId String   @map("announcement_id")
  staffId        String   @map("staff_id")
  announcement   Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  staff          Staff        @relation(fields: [staffId], references: [id])
  readAt         DateTime @default(now()) @map("read_at")

  @@id([announcementId, staffId])
  @@map("announcement_reads")
}

// Feedback submitted by staff to admins/managers.
// Anonymous submission is optional (staffId can be null if anonymized).
model StaffFeedback {
  id          String   @id @default(cuid())
  staffId     String?  @map("staff_id")    // null if submitted anonymously
  staff       Staff?   @relation(fields: [staffId], references: [id])
  staffName   String?  @map("staff_name")  // denormalized for display
  category    String   @default("general") // "general" | "schedule" | "safety" | "suggestion"
  message     String
  isAnonymous Boolean  @default(false) @map("is_anonymous")
  // Status tracked by admins: "new" | "reviewed" | "resolved"
  status      String   @default("new")
  adminNotes  String?  @map("admin_notes")
  resolvedBy  String?  @map("resolved_by")

  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("staff_feedback")
}

// =============================================================================
// OPERATING HOURS & SETTINGS
// =============================================================================

model OperatingHours {
  id          String   @id @default(cuid())
  dayOfWeek   Int      @map("day_of_week")
  openTime    String?  @map("open_time")
  closeTime   String?  @map("close_time")
  closed      Boolean  @default(false)
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@unique([dayOfWeek])
  @@map("operating_hours")
}

model SpecialHours {
  id        String   @id @default(cuid())
  date      DateTime @db.Date @unique
  openTime  String?  @map("open_time")
  closeTime String?  @map("close_time")
  closed    Boolean  @default(false)
  note      String?

  @@map("special_hours")
}

// Resource Hub guides (2026-07-16 addition) — usage documentation for the
// dashboard itself. minAccessLevel restricts visibility: a guide marked
// MANAGER won't be returned to a STAFF-level session at all (filtered
// server-side in /api/guides, not just hidden client-side) — same pattern
// as hasAccess() already used to gate the Admin/Analytics nav links.
model Guide {
  id             String      @id @default(cuid())
  title          String
  body           String
  category       String      @default("General") @map("category")
  minAccessLevel AccessLevel @default(STAFF) @map("min_access_level")
  pinned         Boolean     @default(false)
  sortOrder      Int         @default(0) @map("sort_order")
  authorId       String?     @map("author_id")
  authorName     String      @map("author_name")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("guides")
}

model AppSettings {
  id                String  @id @default("singleton")
  maxPartySize      Int     @default(20) @map("max_party_size")
  bookingWindowDays Int     @default(60) @map("booking_window_days")
  autoConfirm       Boolean @default(false) @map("auto_confirm")
  restaurantName    String  @default("Hive Buckhead") @map("restaurant_name")
  restaurantPhone   String  @default("") @map("restaurant_phone")
  restaurantEmail   String  @default("reservations@thehivebuckhead.com") @map("restaurant_email")
  rsvpFormUrl       String  @default("/rsvp") @map("rsvp_form_url")

  // Integration credential overrides — set from Admin → Settings → Integration
  // Settings. Null means "no override, use the env var from Vercel." A
  // non-null value here always wins. This exists so an admin can rotate a
  // key (or add one that was missing) without needing a redeploy — see
  // src/lib/integrations/settings-override.ts for the resolution order.
  // Nothing here is ever sent back to the client in full — the settings API
  // only ever returns a masked last-4 preview, never the real value.
  sendgridApiKeyOverride String? @map("sendgrid_api_key_override")
  quoApiKeyOverride      String? @map("quo_api_key_override")
  systemeApiKeyOverride  String? @map("systeme_api_key_override")

  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("app_settings")
}
